# ============================================
#  Mykaele Procópio Home Spa — Variáveis de Ambiente
# ============================================

# URL base do app (ajustar em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret (trocar em produção!)
JWT_SECRET=seu-secret-aqui

# Banco de dados
DATABASE_URL="file:./dev.db"

# ─── Google OAuth 2.0 ───
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto ou selecione existente
# 3. Vá em "APIs & Services" → "Credentials"
# 4. Clique "Create Credentials" → "OAuth 2.0 Client ID"
# 5. Tipo: "Web application"
# 6. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
# 7. Em produção adicione: https://seudominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Instagram OAuth (Meta/Facebook) ───
# 1. Acesse https://developers.facebook.com
# 2. Crie um app do tipo "Consumer" ou "Business"
# 3. Adicione o produto "Instagram Basic Display"
# 4. Em "Instagram Basic Display" → "Basic Display":
#    - Valid OAuth Redirect URIs: http://localhost:3000/api/auth/instagram/callback
#    - Deauthorize Callback URL: http://localhost:3000/api/auth/instagram/deauth
#    - Data Deletion Request URL: http://localhost:3000/api/auth/instagram/delete
# 5. Copie o "Instagram App ID" e "Instagram App Secret"
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── Mercado Pago ───
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# ─── WhatsApp (Evolution API / CallMeBot) ───
# WHATSAPP_API_URL=
# WHATSAPP_API_KEY=
# WHATSAPP_INSTANCE=

# ─── Chatbot n8n ───
# N8N_CHATBOT_WEBHOOK_URL=

# ─── Cloudinary (upload de mídia) ───
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ============================================
#  CRM — Variáveis Obrigatórias
# ============================================

# Criptografia AES-256-GCM (credenciais de integrações)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Redis (BullMQ filas + SSE pub/sub)
REDIS_URL=redis://redis:6379

# Evolution API (WhatsApp bidirecional)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# OpenAI (embeddings RAG + Concierge)
OPENAI_API_KEY=

# Multi-tenancy V1
DEFAULT_TENANT_ID=clinica-mykaele-procopio
NEXT_PUBLIC_DEFAULT_TENANT_ID=clinica-mykaele-procopio

# Radar de Retenção (cron diário às 8h)
RETENTION_RADAR_CRON="0 8 * * *"
RETENTION_RISK_THRESHOLD=70

# S3 (mídias WhatsApp — opcional)
S3_ENABLED=false
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ============================================
#  Resend (e-mail transacional)
# ============================================
RESEND_API_KEY=
